9. EfficientTicTacToeRules.java
package rules;

import model.Move;
import model.Player;
import model.PlayerStats;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class EfficientTicTacToeRules
        implements TicTacToeRules {

    private int size;

    private Map<Player, PlayerStats> statsMap;

    public EfficientTicTacToeRules(
            int size,
            List<Player> players
    ) {

        this.size = size;

        statsMap = new HashMap<>();

        for(Player player : players) {
            statsMap.put(player, new PlayerStats(size));
        }
    }

    @Override
    public boolean checkWin(Player player, Move move) {

        int row = move.getRow();
        int col = move.getCol();

        PlayerStats stats = statsMap.get(player);

        stats.rows[row]++;
        stats.cols[col]++;

        if(row == col)
            stats.diagonal++;

        if(row + col == size - 1)
            stats.antiDiagonal++;

        return (
                stats.rows[row] == size ||
                stats.cols[col] == size ||
                stats.diagonal == size ||
                stats.antiDiagonal == size
        );
    }

    @Override
    public boolean checkDraw(int totalMoves) {
        return totalMoves == size * size;
    }
}
