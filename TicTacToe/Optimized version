package game;

import model.Board;
import model.Move;
import model.Player;
import rules.TicTacToeRules;

import java.util.Deque;

public class TicTacToeGame {

    private Board board;

    private Deque<Player> players;

    private TicTacToeRules rules;

    private GameState state;

    private int totalMoves;

    public TicTacToeGame(
            Board board,
            Deque<Player> players,
            TicTacToeRules rules
    ) {
        this.board = board;
        this.players = players;
        this.rules = rules;

        state = GameState.IN_PROGRESS;
    }

    public void play() {

        while(state == GameState.IN_PROGRESS) {

            board.display();

            Player currentPlayer = players.peekFirst();

            Move move =
                    currentPlayer
                    .getStrategy()
                    .makeMove(board);

            boolean success =
                    board.placeMove(
                            move,
                            currentPlayer.getSymbol()
                    );

            if(!success) {
                System.out.println("Invalid move!");
                continue;
            }

            totalMoves++;

            boolean won =
                    rules.checkWin(
                            currentPlayer,
                            move
                    );

            if(won) {

                board.display();

                System.out.println(
                        currentPlayer.getName() + " wins!"
                );

                state = GameState.FINISHED;

                break;
            }

            if(rules.checkDraw(totalMoves)) {

                board.display();

                System.out.println("Draw!");

                state = GameState.DRAW;

                break;
            }

            players.removeFirst();
            players.addLast(currentPlayer);
        }
    }
}
