package model;

import java.util.Objects;

public class Symbol {

    private char mark;

    public Symbol(char mark) {
        this.mark = mark;
    }

    public char getMark() {
        return mark;
    }

    @Override
    public boolean equals(Object o) {
        if(this == o) return true;

        if(o == null || getClass() != o.getClass())
            return false;

        Symbol symbol = (Symbol) o;

        return mark == symbol.mark;
    }

    @Override
    public int hashCode() {
        return Objects.hash(mark);
    }
}
